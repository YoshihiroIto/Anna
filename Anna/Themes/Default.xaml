<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
					xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
	<LinearGradientBrush x:Key="ControlBackgroundBrushKey" EndPoint="0.5,1" StartPoint="0.5,0">
		<GradientStop Color="#FF444444" Offset="0"/>
		<GradientStop Color="#FF2E2E2E" Offset="1"/>
	</LinearGradientBrush>
	<LinearGradientBrush x:Key="ControlInnerEdgeBrushKey" EndPoint="0.5,1" StartPoint="0.5,0">
		<GradientStop Color="#FF5F5E5E" Offset="0"/>
		<GradientStop Color="#FF303030" Offset="1"/>
	</LinearGradientBrush>
	<SolidColorBrush x:Key="ControlOuterEdgeBrushKey" Color="#FF4D4D4D"/>
	<SolidColorBrush x:Key="ControlBorderBrush" Color="Black"/>
	<SolidColorBrush x:Key="ControlTextBrush" Color="#FFB0B0B0"/>
	<LinearGradientBrush x:Key="ControlPressedBackgroundBrush" EndPoint="0.5,1" StartPoint="0.5,0">
		<GradientStop Color="#FF252424" Offset="0"/>
		<GradientStop Color="#FF3E3D3D" Offset="1"/>
	</LinearGradientBrush>
	<LinearGradientBrush x:Key="ControlMouseOverBackgroundBrush" EndPoint="0.5,1" StartPoint="0.5,0">
		<GradientStop Color="#FF515151" Offset="0"/>
		<GradientStop Color="#FF323232" Offset="1"/>
	</LinearGradientBrush>
</ResourceDictionary>
